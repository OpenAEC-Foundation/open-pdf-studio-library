{
  "name": "open-pdf-studio-library",
  "version": "0.1.0",
  "description": "Worldwide symbol, stamp and template library for Open PDF Studio",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenAEC-Foundation/open-pdf-studio-library.git"
  },
  "scripts": {
    "test": "node --test",
    "validate": "node scripts/validate.mjs",
    "build-index": "node scripts/build-index.mjs",
    "check-index": "node scripts/build-index.mjs --check",
    "build-media": "node scripts/build-readme-media.mjs",
    "check-media": "node scripts/build-readme-media.mjs --check",
    "check-versions": "node scripts/check-collection-versions.mjs",
    "build-steel": "node scripts/steel-symbols.mjs",
    "check-steel": "node scripts/steel-symbols.mjs --check"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "saxes": "^6.0.0"
  }
