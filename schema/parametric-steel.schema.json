{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Open PDF Studio Library parametric steel-sections catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "formatVersion", "units", "label", "families"],
  "properties": {
    "format": { "const": "steel-sections" },
    "formatVersion": { "const": 1 },
    "units": { "const": "mm" },
    "label": {
      "type": "object",
      "required": ["en"],
      "additionalProperties": { "type": "string" }
    },
    "families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "shape", "columns", "defaultSize", "sizes"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "name": {
            "type": "object",
            "required": ["en"],
            "additionalProperties": { "type": "string" }
          },
          "shape": { "enum": ["i", "u", "box", "pipe", "angle", "tee"] },
          "columns": {
            "type": "array",
            "minItems": 3,
            "items": { "type": "string" }
          },
          "defaultSize": { "type": "string" },
          "sizes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "array",
              "minItems": 3
            }
          }
        }
      }
    }
  }
}
